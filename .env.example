# Copy to .env (gitignored) and fill in real values, then run ./run-local.sh
#
# Content translation via the Anthropic (Claude) API. When ANTHROPIC_ENABLED is false
# or the key is blank, dynamic content falls back to its English source text.
ANTHROPIC_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
