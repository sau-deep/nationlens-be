<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-01" author="nationlens">
        <validCheckSum>ANY</validCheckSum>
        <createTable tableName="roles">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="code" type="VARCHAR(80)"><constraints unique="true" nullable="false"/></column>
            <column name="name" type="VARCHAR(120)"><constraints nullable="false"/></column>
            <column name="description" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="001-02" author="nationlens">
        <validCheckSum>ANY</validCheckSum>
        <createTable tableName="permissions">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="code" type="VARCHAR(120)"><constraints unique="true" nullable="false"/></column>
            <column name="module" type="VARCHAR(80)"><constraints nullable="false"/></column>
            <column name="description" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="001-03" author="nationlens">
        <validCheckSum>ANY</validCheckSum>
        <createTable tableName="role_permissions">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="role_id" type="BIGINT"><constraints nullable="false" foreignKeyName="fk_rp_role" references="roles(id)"/></column>
            <column name="permission_id" type="BIGINT"><constraints nullable="false" foreignKeyName="fk_rp_permission" references="permissions(id)"/></column>
        </createTable>
        <addUniqueConstraint tableName="role_permissions" columnNames="role_id,permission_id" constraintName="uq_role_permission"/>
    </changeSet>

    <changeSet id="001-04" author="nationlens">
        <validCheckSum>ANY</validCheckSum>
        <createTable tableName="users">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="mobile" type="VARCHAR(20)"><constraints unique="true"/></column>
            <column name="email" type="VARCHAR(255)"><constraints unique="true"/></column>
            <column name="password_hash" type="VARCHAR(255)"/>
            <column name="display_name" type="VARCHAR(255)"/>
            <column name="preferred_language" type="VARCHAR(10)" defaultValue="en"/>
            <column name="district_id" type="BIGINT"/>
            <column name="contribution_score" type="INT" defaultValueNumeric="0"/>
            <column name="gamification_level" type="VARCHAR(60)" defaultValue="CITIZEN"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="email_verified" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="mobile_verified" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="001-05" author="nationlens">
        <validCheckSum>ANY</validCheckSum>
        <createTable tableName="user_roles">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="user_id" type="BIGINT"><constraints nullable="false" foreignKeyName="fk_ur_user" references="users(id)"/></column>
            <column name="role_id" type="BIGINT"><constraints nullable="false" foreignKeyName="fk_ur_role" references="roles(id)"/></column>
            <column name="scope_type" type="VARCHAR(40)"/>
            <column name="scope_id" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="001-06" author="nationlens">
        <validCheckSum>ANY</validCheckSum>
        <createTable tableName="otp_requests">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="mobile" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="otp_hash" type="VARCHAR(256)"><constraints nullable="false"/></column>
            <column name="expires_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="used" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
