<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003-01" author="nationlens">
        <createTable tableName="entity_types">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="code" type="VARCHAR(80)"><constraints unique="true" nullable="false"/></column>
            <column name="name_en" type="VARCHAR(120)"><constraints nullable="false"/></column>
            <column name="name_hi" type="VARCHAR(120)"/>
        </createTable>
    </changeSet>

    <changeSet id="003-02" author="nationlens">
        <createTable tableName="entities">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="entity_type_id" type="BIGINT"><constraints nullable="false" foreignKeyName="fk_entity_type" references="entity_types(id)"/></column>
            <column name="name_en" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="name_hi" type="VARCHAR(255)"/>
            <column name="slug" type="VARCHAR(300)"><constraints unique="true" nullable="false"/></column>
            <column name="description_en" type="TEXT"/>
            <column name="description_hi" type="TEXT"/>
            <column name="party_entity_id" type="BIGINT"/>
            <column name="district_id" type="BIGINT"><constraints foreignKeyName="fk_entity_district" references="districts(id)"/></column>
            <column name="constituency_id" type="BIGINT"><constraints foreignKeyName="fk_entity_constituency" references="constituencies(id)"/></column>
            <column name="state_id" type="BIGINT"><constraints foreignKeyName="fk_entity_state" references="states(id)"/></column>
            <column name="image_url" type="TEXT"/>
            <column name="verified" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="status" type="VARCHAR(40)" defaultValue="ACTIVE"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
        <createIndex tableName="entities" indexName="idx_entities_slug"><column name="slug"/></createIndex>
        <createIndex tableName="entities" indexName="idx_entities_type"><column name="entity_type_id"/></createIndex>
        <createIndex tableName="entities" indexName="idx_entities_district"><column name="district_id"/></createIndex>
    </changeSet>

    <changeSet id="003-03" author="nationlens">
        <createTable tableName="political_profiles">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="entity_id" type="BIGINT"><constraints unique="true" nullable="false" foreignKeyName="fk_pol_entity" references="entities(id)"/></column>
            <column name="education" type="VARCHAR(500)"/>
            <column name="declared_criminal_cases" type="INT" defaultValueNumeric="0"/>
            <column name="declared_assets_inr" type="BIGINT"/>
            <column name="declared_liabilities_inr" type="BIGINT"/>
            <column name="parliament_attendance_pct" type="DECIMAL(5,2)"/>
            <column name="questions_raised" type="INT" defaultValueNumeric="0"/>
            <column name="bills_introduced" type="INT" defaultValueNumeric="0"/>
            <column name="term_start_year" type="INT"/>
            <column name="accountability_score" type="INT"/>
            <column name="affidavit_source_url" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
