<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="007-01" author="nationlens">
        <createTable tableName="manifesto_promises">
            <column name="id" type="BIGSERIAL"><constraints primaryKey="true"/></column>
            <column name="party_entity_id" type="BIGINT"><constraints nullable="false" foreignKeyName="fk_promise_party" references="entities(id)"/></column>
            <column name="category_key" type="VARCHAR(80)"><constraints nullable="false"/></column>
            <column name="title_en" type="VARCHAR(500)"><constraints nullable="false"/></column>
            <column name="title_hi" type="VARCHAR(500)"/>
            <column name="description_en" type="TEXT"/>
            <column name="status" type="VARCHAR(40)" defaultValue="NOT_STARTED"/>
            <column name="election_year" type="INT"><constraints nullable="false"/></column>
            <column name="source_url" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
