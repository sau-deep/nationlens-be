<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="010-01" author="nationlens">
        <createTable tableName="audit_logs">
            <column name="id" type="BIGSERIAL"><constraints primaryKey="true"/></column>
            <column name="table_name" type="VARCHAR(80)"><constraints nullable="false"/></column>
            <column name="record_id" type="BIGINT"/>
            <column name="action" type="VARCHAR(40)"><constraints nullable="false"/></column>
            <column name="old_values" type="JSONB"/>
            <column name="new_values" type="JSONB"/>
            <column name="performed_by" type="BIGINT"><constraints foreignKeyName="fk_audit_user" references="users(id)"/></column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <createIndex tableName="audit_logs" indexName="idx_audit_created"><column name="created_at" descending="true"/></createIndex>
    </changeSet>

</databaseChangeLog>
