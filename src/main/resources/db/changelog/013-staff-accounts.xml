                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        Staff accounts — email/password login only.
        Citizens use mobile OTP login instead.
        Passwords are BCrypt(rounds=10). See docs/Staff_Credentials.md for plaintext.
    -->

    <!-- NATIONAL_ADMIN -->
    <changeSet id="013-01" author="nationlens">
        <insert tableName="users">
            <column name="email" value="national@nationlens.in"/>
            <column name="display_name" value="National Admin"/>
            <column name="password_hash" value="$2b$10$uzTHi8b33GnFdCqkIo8.0OMLx2DtLFPFG78GzU3qKhEDFnMzCzfhy"/>
            <column name="email_verified" valueBoolean="true"/>
            <column name="is_active" valueBoolean="true"/>
        </insert>
        <insert tableName="user_roles">
            <column name="user_id" valueComputed="(SELECT id FROM users WHERE email='national@nationlens.in')"/>
            <column name="role_id" valueComputed="(SELECT id FROM roles WHERE code='NATIONAL_ADMIN')"/>
        </insert>
    </changeSet>

