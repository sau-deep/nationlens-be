    <!-- ================================================================
         New public-figure / influencer entities for Instagram reels
         ================================================================ -->
    <changeSet id="017-01" author="nationlens">
        <validCheckSum>ANY</validCheckSum>

        <!-- Civic influencer — Delhi based -->
        <insert tableName="entities">
            <column name="entity_type_id" valueComputed="(SELECT id FROM entity_types WHERE code='INFLUENCER')"/>
            <column name="name_en" value="Ananya Kapoor"/>
            <column name="name_hi" value="अनन्या कपूर"/>
            <column name="slug" value="ananya-kapoor-civic"/>
            <column name="description_en" value="Digital civic educator and Instagram creator with 1.2M followers. Creates reels explaining Indian laws, voter rights, and RTI."/>
