<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Denormalize language onto news items for fast locale filtering -->
    <changeSet id="020-01" author="nationlens">
        <addColumn tableName="rss_news_items">
            <column name="source_language" type="VARCHAR(10)" defaultValue="EN"/>
        </addColumn>
        <sql>
            UPDATE rss_news_items n
            SET source_language = COALESCE(
                (SELECT s.source_language FROM rss_feed_sources s WHERE s.id = n.feed_source_id),
                'EN'
            )
            WHERE n.source_language IS NULL OR n.source_language = 'EN';
        </sql>
    </changeSet>

