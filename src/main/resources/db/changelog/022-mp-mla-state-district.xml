<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        Backfill state_id (and fix two district_id references) for all MP / MLA
        entities. Every politician already had a district_id but state_id was NULL.

        Constituency → district → state mapping verified against public records
        (Wikipedia / MyNeta, 18th Lok Sabha 2024 results and current state
        assemblies). All referenced state codes and district slugs already exist
        in 002-geography / 011 / 014, except Rae Bareli which is added below.
    -->

    <!-- ── Missing district: Rae Bareli (Rahul Gandhi's 2024 LS seat) ──────── -->
    <changeSet id="022-01" author="nationlens">
        <validCheckSum>ANY</validCheckSum>
        <preConditions onFail="MARK_RAN"><sqlCheck expectedResult="0">SELECT COUNT(*) FROM districts WHERE slug = 'rae-bareli'</sqlCheck></preConditions>
        <insert tableName="districts">
            <column name="state_id" valueComputed="(SELECT id FROM states WHERE code='UP')"/>
            <column name="name_en" value="Rae Bareli"/><column name="name_hi" value="रायबरेली"/>
            <column name="slug" value="rae-bareli"/><column name="population" valueNumeric="3405559"/>
            <column name="literacy_rate" valueNumeric="67.3"/><column name="headquarters" value="Rae Bareli"/>
        </insert>
    </changeSet>

    <!-- ── Fix two district_id references ─────────────────────────────────── -->
    <changeSet id="022-02" author="nationlens">
        <validCheckSum>ANY</validCheckSum>
        <comment>Rahul Gandhi sits for Rae Bareli (was lucknow); Atishi for Kalkaji in Delhi (was broken slug 'delhi').</comment>
        <update tableName="entities">
            <column name="district_id" valueComputed="(SELECT id FROM districts WHERE slug='rae-bareli')"/>
            <where>slug = 'rahul-gandhi'</where>
        </update>
        <update tableName="entities">
            <column name="district_id" valueComputed="(SELECT id FROM districts WHERE slug='new-delhi')"/>
            <where>slug = 'atishi'</where>
        </update>
    </changeSet>

