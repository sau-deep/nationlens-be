<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- ================================================================
         MEDIA OWNERSHIP
         Who owns the media. A self-referencing tree so we can model
         "top companies owning big companies":
           Conglomerate  ->  Media House  ->  Channel / Outlet
         e.g. Reliance Industries -> Network18 -> CNN-News18
         owner_type: CONGLOMERATE | MEDIA_HOUSE | CHANNEL | DIGITAL
                     | GOVERNMENT | INDEPENDENT
         ================================================================ -->
    <changeSet id="023-01" author="nationlens">
        <validCheckSum>ANY</validCheckSum>
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="media_owners"/></not></preConditions>
        <createTable tableName="media_owners">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="slug" type="VARCHAR(160)"><constraints unique="true" nullable="false"/></column>
            <column name="name_en" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="name_hi" type="VARCHAR(255)"/>
            <column name="owner_type" type="VARCHAR(40)"><constraints nullable="false"/></column>
            <!-- self reference: the bigger company that owns this one -->
            <column name="parent_owner_id" type="BIGINT"><constraints foreignKeyName="fk_owner_parent" references="media_owners(id)"/></column>
            <column name="controlled_by" type="VARCHAR(255)"/>
            <column name="ownership_note_en" type="TEXT"/>
            <column name="ownership_note_hi" type="TEXT"/>
            <column name="logo_url" type="TEXT"/>
            <column name="website" type="TEXT"/>
            <column name="hq_location" type="VARCHAR(160)"/>
            <column name="founded_year" type="INT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <createIndex tableName="media_owners" indexName="idx_media_owners_slug"><column name="slug"/></createIndex>
        <createIndex tableName="media_owners" indexName="idx_media_owners_parent"><column name="parent_owner_id"/></createIndex>
        <createIndex tableName="media_owners" indexName="idx_media_owners_type"><column name="owner_type"/></createIndex>
    </changeSet>

    <!-- Link every media item to a structured owner (keeps source_owner text too) -->
    <changeSet id="023-02" author="nationlens">
        <validCheckSum>ANY</validCheckSum>
        <preConditions onFail="MARK_RAN"><not><columnExists tableName="media_links" columnName="owner_id"/></not></preConditions>
        <addColumn tableName="media_links">
            <column name="owner_id" type="BIGINT"><constraints foreignKeyName="fk_media_owner" references="media_owners(id)"/></column>
        </addColumn>
        <createIndex tableName="media_links" indexName="idx_media_links_owner"><column name="owner_id"/></createIndex>
    </changeSet>

