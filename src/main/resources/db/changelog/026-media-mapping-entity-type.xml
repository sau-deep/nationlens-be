<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="026-01" author="nationlens">
        <validCheckSum>ANY</validCheckSum>
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="media_mappings" columnName="entity_type_code"/></not>
        </preConditions>
        <addColumn tableName="media_mappings">
            <column name="entity_type_code" type="VARCHAR(40)"/>
        </addColumn>
        <createIndex tableName="media_mappings" indexName="idx_media_mappings_entity_type">
            <column name="entity_type_code"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
